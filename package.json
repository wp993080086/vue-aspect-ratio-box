{
	"name": "vue-aspect-ratio-box",
	"version": "1.2.1",
	"description": "Vue Aspect Ratio component, compatible with Vue 3 & Vue 2.7+, supports custom fixed width/height and auto adaptive layout.",
	"main": "dist/index.umd.js",
	"module": "dist/index.es.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.es.js",
			"require": "./dist/index.umd.js"
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"README_en.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"scripts": {
		"build": "vite build",
		"build:types": "vue-tsc --declaration --emitDeclarationOnly",
		"dev": "vite",
		"preview": "vite preview",
		"prepublishOnly": "npm run build && npm run build:types"
	},
	"keywords": [
		"vue",
		"vue2",
		"vue3",
		"vue-component",
		"vue-plugin",
		"vue-demi",
		"aspect-ratio",
		"aspect-ratio-box",
		"ratio-box",
		"responsive",
		"responsive-layout",
		"adaptive-layout",
		"fixed-width",
		"fixed-height",
		"video-container",
		"image-container",
		"card-layout",
		"component",
		"typescript",
		"tree-shaking"
	],
	"author": "wp993080086 <993080086@qq.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wp993080086/vue-aspect-ratio-box.git"
	},
	"bugs": {
		"url": "https://github.com/wp993080086/vue-aspect-ratio-box/issues"
	},
	"homepage": "https://github.com/wp993080086/vue-aspect-ratio-box#readme",
	"peerDependencies": {
		"vue": "^2.7.0 || ^3.0.0"
	},
	"dependencies": {
		"vue-demi": "^0.14.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@vitejs/plugin-vue": "^4.0.0",
		"terser": "^5.43.1",
		"typescript": "^4.9.0",
		"vite": "^4.0.0",
		"vue": "^3.2.0",
		"vue-tsc": "^1.0.0"
	}
}
